a8b953da813a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"matBlock", "[", 
    RowBox[{
    "\[Phi]_", ",", "\[Rho]_", ",", "c11_", ",", "c12_", ",", "c44_", ",", 
     "\[Omega]_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["k", "2"], "*", "c11", "*", 
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Phi]", "]"}], "2"]}], "+", 
        RowBox[{
         SuperscriptBox["k", "2"], "*", "c44", "*", 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}], "-", 
        RowBox[{"\[Rho]", "*", 
         SuperscriptBox["\[Omega]", "2"]}]}], ",", 
       RowBox[{
        SuperscriptBox["k", "2"], "*", 
        RowBox[{"(", 
         RowBox[{"c12", "+", "c44"}], ")"}], "*", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}], "*", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SuperscriptBox["k", "2"], "*", 
        RowBox[{"(", 
         RowBox[{"c12", "+", "c44"}], ")"}], "*", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}], "*", 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["k", "2"], "*", "c11", "*", 
         SuperscriptBox[
          RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}], "+", 
        RowBox[{
         SuperscriptBox["k", "2"], "*", "c44", "*", 
         SuperscriptBox[
          RowBox[{"Cos", "[", "\[Phi]", "]"}], "2"]}], "-", 
        RowBox[{"\[Rho]", "*", 
         SuperscriptBox["\[Omega]", "2"]}]}]}], "}"}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]1", "[", 
    RowBox[{
    "\[Phi]_", ",", "\[Rho]_", ",", "c11_", ",", "c12_", ",", "c44_", ",", 
     "\[Omega]_", ",", "k_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Assuming", "[", 
     RowBox[{
      RowBox[{"k", ">", "0"}], ",", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"Eigenvalues", "[", 
        RowBox[{"matBlock", "[", 
         RowBox[{
         "\[Phi]", ",", "\[Rho]", ",", "c11", ",", "c12", ",", "c44", ",", 
          "\[Omega]", ",", "k"}], "]"}], "]"}], "]"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Lambda]2", "[", 
    RowBox[{
    "\[Phi]_", ",", "\[Rho]_", ",", "c11_", ",", "c12_", ",", "c44_", ",", 
     "\[Omega]_", ",", "k_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"Assuming", "[", 
     RowBox[{
      RowBox[{"k", ">", "0"}], ",", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"Eigenvalues", "[", 
        RowBox[{"matBlock", "[", 
         RowBox[{
         "\[Phi]", ",", "\[Rho]", ",", "c11", ",", "c12", ",", "c44", ",", 
          "\[Omega]", ",", "k"}], "]"}], "]"}], "]"}]}], "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.8477939241538973`*^9, 3.8477939359173326`*^9}, {
   3.8477939905765147`*^9, 3.8477941015364103`*^9}, {3.847794136149485*^9, 
